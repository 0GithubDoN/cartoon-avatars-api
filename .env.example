# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Figma Configuration
# --------------------
# FIGMA_ACCESS_TOKEN: Your Figma API access token for authentication
# Get your token from: https://www.figma.com/developers/api#access-tokens
# Required for: Extracting avatar images from Figma design files
# Permissions needed: Read access to the Figma file
FIGMA_ACCESS_TOKEN=your_figma_access_token_here

# FIGMA_FILE_URL: Full URL to the Figma file containing avatars
# Must include the node-id parameter pointing to the parent node with avatars
# Example: https://www.figma.com/design/FILE_ID/FILE_NAME?node-id=0-1
# Required for: Identifying which Figma file and node to extract avatars from
FIGMA_FILE_URL=https://www.figma.com/design/5e2jjfUFI76Em5stj9Oe7p/Cartoon-Avatars-%7C-Animals---Birds-%7C-200--Free-Characters--Community-?node-id=0-1

# GitHub Configuration
# --------------------
# GITHUB_TOKEN: Your GitHub personal access token for authentication
# Get your token from: https://github.com/settings/tokens
# Required for: Uploading avatars to GitHub repository and serving them via API
# Permissions needed: 'repo' scope (full control of repositories)
GITHUB_TOKEN=your_github_personal_access_token_here

# GITHUB_REPO: Target GitHub repository for storing avatars
# Format: owner/repo (e.g., "johndoe/avatar-storage")
# Required for: Determining where to upload and retrieve avatar files
# Note: Repository should be public for direct image access, or token must have access
GITHUB_REPO=your-username/your-repo-name

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# API Server Configuration
# ------------------------
# PORT: HTTP port for the API server to listen on
# Default: 3000
# Used by: API server (server.js)
PORT=3000

# CACHE_REFRESH_INTERVAL: How often to refresh the avatar list cache (milliseconds)
# Default: 300000 (5 minutes)
# Used by: API server cache manager
# Lower values = more GitHub API calls, higher values = potentially stale data
CACHE_REFRESH_INTERVAL=300000

# Rate Limiting Configuration
# ---------------------------
# RATE_LIMIT_DELAY: Minimum delay between consecutive Figma API requests (milliseconds)
# Default: 1000 (1 second)
# Used by: Extraction service rate limiter
# Purpose: Prevents hitting Figma API rate limits
RATE_LIMIT_DELAY=1000

# MAX_CONCURRENT_REQUESTS: Maximum number of concurrent Figma API requests
# Default: 1
# Used by: Extraction service rate limiter
# Purpose: Prevents overwhelming the Figma API
MAX_CONCURRENT_REQUESTS=1

# MAX_UPLOAD_RETRIES: Maximum number of retry attempts for failed GitHub uploads
# Default: 3
# Used by: GitHub client upload logic
# Purpose: Handles transient network failures gracefully
MAX_UPLOAD_RETRIES=3
