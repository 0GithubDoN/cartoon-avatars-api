{
  "name": "avatar-api-project",
  "version": "1.0.0",
  "description": "Avatar API system that extracts cartoon avatar PNG images from Figma, stores them in GitHub, and serves them via HTTP API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "extract": "node src/extractor.js",
    "extract:test": "node src/extractor.js --test",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:property": "jest tests/property",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "avatar",
    "api",
    "figma",
    "github",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "fast-check": "^3.15.0",
    "supertest": "^6.3.3",
    "nock": "^13.5.0"
  }
}
